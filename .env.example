# ================================================================
# Personal Assistant 环境变量模板
# ================================================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入实际的值（引号可选，但包含特殊字符时建议加引号）
# 3. .env 文件已被 .gitignore 忽略，不会提交到版本库
# ================================================================

# ======================== 数据库配置 ========================
# MySQL 连接信息
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ======================== Redis 配置 ========================
REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ======================== JWT 认证配置 ========================
# 访问令牌密钥（建议使用 64 位随机字符串）
JWT_ACCESS_TOKEN_SECRET=replace_with_a_64_char_random_string
# 刷新令牌密钥（建议使用 64 位随机字符串）
JWT_REFRESH_TOKEN_SECRET=replace_with_another_64_char_random_string

# ======================== Session 配置 ========================
SYSTEM_SESSIONS_SECRET=your_session_secret_here

# ======================== 邮件配置 ========================
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_FROM=your_email@example.com
EMAIL_NICKNAME=个人助手
EMAIL_SECRET=your_email_app_password
EMAIL_IS_SSL=true

# ======================== 七牛云存储配置 ========================
# 当前使用的存储驱动：local 或 qiniu
STORAGE_CURRENT=qiniu
# 七牛云配置（使用 qiniu 驱动时必填）
STORAGE_QINIU_BUCKET=your_qiniu_bucket
STORAGE_QINIU_DOMAIN=https://your-cdn-domain.example.com
STORAGE_QINIU_ACCESS_KEY=your_qiniu_access_key
STORAGE_QINIU_SECRET_KEY=your_qiniu_secret_key

# ======================== 高德地图配置 ========================
GAODE_ENABLE=false
GAODE_KEY=your_gaode_api_key

# ======================== QQ 登录配置 ========================
QQ_ENABLE=false
QQ_APP_ID=your_qq_app_id
QQ_APP_KEY=your_qq_app_key
QQ_REDIRECT_URI=http://localhost:8002/callback/qq

# ======================== 爬虫服务配置 ========================
CRAWLER_LEETCODE_BASE_URL=http://127.0.0.1:8001
CRAWLER_LEETCODE_API_PREFIX=/v2
CRAWLER_LUOGU_BASE_URL=http://127.0.0.1:8001
CRAWLER_LUOGU_API_PREFIX=/v2
CRAWLER_LANQIAO_BASE_URL=http://127.0.0.1:8001
CRAWLER_LANQIAO_API_PREFIX=/v2
LANQIAO_TIMEOUT_MS=10000
LANQIAO_MAX_IDLE_CONNS=100
LANQIAO_MAX_IDLE_CONNS_PER_HOST=40
LANQIAO_IDLE_CONN_TIMEOUT_SEC=90
LANQIAO_RETRY_COUNT=2
LANQIAO_RETRY_WAIT_MS=200
LANQIAO_RETRY_MAX_WAIT_MS=2000
LANQIAO_RESPONSE_BODY_LIMIT_BYTES=4194304

# ======================== 系统配置 ========================
SYSTEM_HOST=0.0.0.0
SYSTEM_PORT=9000
SYSTEM_ENV=dev
# 自动迁移数据库表结构
AUTO_MIGRATE=true

# ======================== Observability 配置 ========================
OBSERVABILITY_ENABLED=true
OBSERVABILITY_SERVICE_NAME=personal_assistant
OBSERVABILITY_PROPAGATION_REQUEST_ID_HEADER=X-Request-ID
OBSERVABILITY_PROPAGATION_PARSE_W3C=true
OBSERVABILITY_PROPAGATION_INJECT_W3C=true
OBSERVABILITY_METRICS_FLUSH_INTERVAL_MS=1000
OBSERVABILITY_METRICS_DB_BATCH_SIZE=500
OBSERVABILITY_METRICS_FINE_RETENTION_DAYS=45
OBSERVABILITY_METRICS_DAY_RETENTION_DAYS=365
OBSERVABILITY_METRICS_WEEK_RETENTION_DAYS=0
OBSERVABILITY_METRICS_ROLLUP_CRON=10 2 * * *
OBSERVABILITY_TRACES_ENABLED=true
OBSERVABILITY_TRACES_STREAM_KEY=traces:stream
OBSERVABILITY_TRACES_STREAM_GROUP=traces_persist_group
OBSERVABILITY_TRACES_STREAM_CONSUMER=go_trace_consumer
OBSERVABILITY_TRACES_STREAM_READ_COUNT=200
OBSERVABILITY_TRACES_STREAM_BLOCK_MS=1000
OBSERVABILITY_TRACES_PENDING_IDLE_MS=60000
OBSERVABILITY_TRACES_DB_BATCH_SIZE=100
OBSERVABILITY_TRACES_DB_FLUSH_INTERVAL_MS=800
OBSERVABILITY_TRACES_NORMAL_QUEUE_SIZE=4096
OBSERVABILITY_TRACES_CRITICAL_QUEUE_SIZE=1024
OBSERVABILITY_TRACES_ENQUEUE_TIMEOUT_MS=30
OBSERVABILITY_TRACES_SUCCESS_SAMPLE_RATE=1
OBSERVABILITY_TRACES_DROP_SUCCESS_ON_OVERLOAD=true
OBSERVABILITY_TRACES_CAPTURE_ERROR_PAYLOAD=true
OBSERVABILITY_TRACES_MAX_PAYLOAD_BYTES=4096
OBSERVABILITY_TRACES_CAPTURE_ERROR_STACK=true
OBSERVABILITY_TRACES_CAPTURE_ERROR_DETAIL=true
OBSERVABILITY_TRACES_MAX_STACK_BYTES=8192
OBSERVABILITY_TRACES_MAX_DETAIL_BYTES=4096
OBSERVABILITY_TRACES_SUCCESS_RETENTION_DAYS=5
OBSERVABILITY_TRACES_ERROR_RETENTION_DAYS=10
OBSERVABILITY_TRACES_CLEANUP_CRON=30 2 * * *

# ======================== Task / Messaging 配置 ========================
TASK_OUTBOX_CLEANUP_RETENTION_DAYS=7
TASK_OUTBOX_FAILED_CLEANUP_RETENTION_DAYS=30
TASK_DISTRIBUTED_LOCK_ENABLED=true
TASK_DISTRIBUTED_LOCK_TTL_SECONDS=30
TASK_IMAGE_ORPHAN_CLEANUP_CRON=@daily
MESSAGING_OUTBOX_RELAY_LOCK_ENABLED=true
MESSAGING_OUTBOX_RELAY_LOCK_TTL_SECONDS=15
