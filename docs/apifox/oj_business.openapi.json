            "$ref": "#/components/schemas/OJCurveRespData"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "服务端响应时间戳，毫秒。"
          }
        },
        "required": [
          "code",
          "success",
          "message",
          "data",
          "timestamp"
        ]
      },
      "BizErrorResponse": {
        "type": "object",
        "description": "新版 BizResponse 失败壳。",
        "properties": {
          "code": {
            "type": "integer",
            "description": "业务错误码。常见值：10002=参数绑定失败，10005=数据库错误，40002=账号已绑定，40006=OJ数据同步失败，40007=OJ凭据无效。"
          },
          "success": {
            "type": "boolean",
            "enum": [
              false
            ],
            "description": "固定为 false。"
          },
          "message": {
            "type": "string",
            "description": "业务错误消息。Service 返回 BizError 时通常使用错误码默认文案或自定义业务提示。"
          },
          "data": {
            "nullable": true,
            "description": "失败时通常为 null。"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "服务端响应时间戳，毫秒。"
          }
        },
        "required": [
          "code",
          "success",
          "message",
          "data",
          "timestamp"
        ]
      },
      "AuthResponseData": {
        "type": "object",
        "description": "JWTAuth 旧版认证失败响应中的 data 结构。",
        "properties": {
          "message": {
            "type": "string",
            "description": "认证失败原因。"
          },
          "reload": {
            "type": "boolean",
            "description": "提示前端应重置状态并重新登录。"
          }
        },
        "required": [
          "message",
          "reload"
        ]
      },
      "LegacyTokenErrorResponse": {
        "type": "object",
        "description": "JWTAuth 中间件返回的旧版认证失败响应壳。",
        "properties": {
          "code": {
            "type": "integer",
            "enum": [
              11001,
              11003,
              11005
            ],
            "description": "认证相关业务码。11005=需要登录，11001=Token 已过期，11003=Token 无效。"
          },
          "data": {
            "$ref": "#/components/schemas/AuthResponseData"
          },
          "error": {
            "type": "string",
            "description": "认证失败原因。"
          }
        },
        "required": [
          "code",
          "data",
          "error"
        ]
      },
      "BizUnauthorizedResponse": {
        "type": "object",
        "description": "ActiveUserMW 拦截时返回的 HTTP 401 响应。",
        "properties": {
          "code": {
            "type": "integer",
            "enum": [
              11000
            ],
            "description": "未授权业务码。"
          },
          "success": {
            "type": "boolean",
            "enum": [
              false
            ],
            "description": "固定为 false。"
          },
          "message": {
            "type": "string",
            "description": "未授权说明，例如账号已禁用。"
          },
          "data": {
            "nullable": true,
            "description": "当前中间件返回为 null。"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "服务端响应时间戳，毫秒。"
          }
        },
        "required": [
          "code",
          "success",
          "message",
          "data",
          "timestamp"
        ]
      }
    }
  }
}
