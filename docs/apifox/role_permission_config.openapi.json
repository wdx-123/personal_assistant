    "/system/role/assign_permission": {
      "post": {
        "tags": [
          "系统-角色权限配置"
        ],
        "summary": "保存角色权限配置",
        "description": "单次请求内全量替换角色的三类权限：\n- role_menus：角色菜单权限\n- role_apis：角色直绑 API 权限\n- role_capabilities：角色 capability 权限\n\n处理流程：\n1. 按角色维度加 Redis 锁，防止并发覆盖\n2. 校验角色是否存在\n3. 对 menu_ids 去重后逐个过滤，只保留真实存在的菜单 ID；无效 menu_id 会被静默忽略\n4. 对 direct_api_ids 去重后逐个过滤，只保留真实存在的 API ID；无效 api_id 会被静默忽略\n5. 对 capability_codes 做 trim + 去重 + 排序；若任一 code 无效，则直接返回参数错误\n6. 在单个事务内同时替换菜单、直绑 API、capability 关系\n7. 提交成功后立即刷新全量权限到 Casbin\n\n重要语义：\n- 这是全量替换接口，不是增量追加；前端必须传完整目标状态。\n- menu_ids、direct_api_ids、capability_codes 三个字段必须传入，允许为空数组；空数组表示清空该维度权限。\n- 若事务提交成功但后续权限刷新失败，接口会返回失败，但数据库中权限关系可能已更新。",
        "operationId": "AssignRolePermissionConfig",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignRolePermissionReq"
              },
              "examples": {
                "保存完整权限": {
                  "summary": "同时保存菜单、直绑 API、capability",
                  "value": {
                    "role_id": 3,
                    "menu_ids": [
                      13,
                      14
                    ],
                    "direct_api_ids": [
                      99,
                      100
                    ],
                    "capability_codes": [
                      "org.member.assign_role",
                      "org.member.invite"
                    ]
                  }
                },
                "清空全部权限": {
                  "summary": "三个数组均传空，表示清空角色权限",
                  "value": {
                    "role_id": 3,
                    "menu_ids": [],
                    "direct_api_ids": [],
                    "capability_codes": []
                  }
                },
                "仅保留capability": {
                  "summary": "菜单和直绑 API 清空，只保留 capability",
                  "value": {
                    "role_id": 5,
                    "menu_ids": [],
                    "direct_api_ids": [],
                    "capability_codes": [
                      "org.member.assign_role"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功、业务失败、JWT/权限中间件拦截均可能返回 HTTP 200，需结合响应结构与 code 判断",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/BizResponseMessage"
                    },
                    {
                      "$ref": "#/components/schemas/BizResponseError"
                    },
                    {
                      "$ref": "#/components/schemas/LegacyTokenErrorResponse"
                    },
                    {
                      "$ref": "#/components/schemas/LegacyErrorEnvelope"
                    }
                  ]
                },
                "examples": {
                  "保存成功": {
                    "summary": "角色权限更新成功",
                    "value": {
                      "code": 0,
                      "success": true,
                      "message": "分配成功",
                      "data": null,
                      "timestamp": 1770732001001
                    }
                  },
                  "缺少必传数组字段": {
                    "summary": "capability_codes 未传时的控制器校验失败",
                    "value": {
                      "code": 10001,
                      "success": false,
                      "message": "capability_codes 必须传入（可为空数组）",
                      "data": null,
                      "timestamp": 1770732001002
                    }
                  },
                  "存在无效capability": {
                    "summary": "任一 capability_code 无效都会直接失败",
                    "value": {
                      "code": 10001,
                      "success": false,
                      "message": "存在无效 capability_codes",
                      "data": null,
                      "timestamp": 1770732001003
                    }
                  },
                  "角色不存在": {
                    "summary": "role_id 不存在",
                    "value": {
                      "code": 30101,
                      "success": false,
                      "message": "角色不存在",
                      "data": null,
                      "timestamp": 1770732001004
                    }
                  },
                  "锁冲突": {
                    "summary": "同一角色短时间内并发提交，命中 Redis 锁",
                    "value": {
                      "code": 10008,
                      "success": false,
                      "message": "操作过于频繁，请稍后重试",
                      "data": null,
                      "timestamp": 1770732001005
                    }
                  },
                  "Token无效_旧壳响应": {
                    "summary": "JWTAuth 中间件返回旧版响应壳",
                    "value": {
                      "code": 11003,
                      "data": {
                        "message": "Invalid access token",
                        "reload": true
                      },
                      "error": "Invalid access token"
                    }
                  },
                  "权限不足_旧壳响应": {
                    "summary": "PermissionMiddleware 拦截",
                    "value": {
                      "code": 11006,
                      "data": {},
                      "error": "用户无权限访问API"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "ActiveUserMW 拦截，例如账号已禁用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BizResponseUnauthorized"
                },
                "example": {
                  "code": 11000,
                  "success": false,
                  "message": "账号已禁用",
                  "data": null,
                  "timestamp": 1770732001006
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "标准 Bearer Token 方式：Authorization: Bearer <access_token>"
      },
      "AccessTokenHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-access-token",
        "description": "仓库当前 JWT 中间件同样支持 x-access-token 头"
      }
    },
    "schemas": {
      "AssignRolePermissionReq": {
        "type": "object",
        "required": [
          "role_id",
          "menu_ids",
          "direct_api_ids",
          "capability_codes"
        ],
        "properties": {
          "role_id": {
            "type": "integer",
            "format": "int64",
            "minimum": 1,
            "description": "角色 ID。必须是已存在角色。",
            "example": 3
          },
          "menu_ids": {
            "type": "array",
            "description": "角色菜单 ID 列表。必传，可为空数组。语义为全量替换；传空数组表示清空角色菜单权限。后端会去重，并静默忽略不存在的菜单 ID。",
            "items": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "example": [
              13,
              14
            ]
          },
          "direct_api_ids": {
            "type": "array",
            "description": "角色直绑 API ID 列表。必传，可为空数组。语义为全量替换；传空数组表示清空角色直绑 API 权限。后端会去重，并静默忽略不存在的 API ID。",
            "items": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "example": [
              99,
              100
            ]
          },
          "capability_codes": {
            "type": "array",
            "description": "角色 capability code 列表。必传，可为空数组。语义为全量替换；传空数组表示清空 capability 权限。后端会 trim、去重、排序；只要存在任一无效 code，就直接返回 10001。",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "example": [
              "org.member.assign_role",
              "org.member.invite"
            ]
          }
        }
      },
      "BizResponseMessage": {
        "type": "object",
        "required": [
          "code",
          "success",
          "message",
          "timestamp"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "业务码，0 表示成功",
            "example": 0
          },
          "success": {
            "type": "boolean",
            "description": "是否成功",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "业务消息",
            "example": "分配成功"
          },
          "data": {
            "nullable": true,
            "description": "该类成功响应通常为 null",
            "example": null
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "毫秒时间戳",
            "example": 1770732001001
          }
        }
      },
      "BizResponseError": {
        "type": "object",
        "required": [
          "code",
