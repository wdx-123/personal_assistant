          },
          "message": {
            "type": "string",
            "example": "账号已禁用"
          },
          "data": {
            "nullable": true,
            "example": null
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "example": 1770732001006
          }
        }
      },
      "BizResponseRolePermissionConfigMap": {
        "type": "object",
        "required": [
          "code",
          "success",
          "message",
          "data",
          "timestamp"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "$ref": "#/components/schemas/RoleMenuAPIMappingItem"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "example": 1770732000001
          }
        }
      },
      "RoleMenuAPIMappingItem": {
        "type": "object",
        "required": [
          "menu_tree"
        ],
        "properties": {
          "menu_tree": {
            "type": "array",
            "description": "菜单树。根节点 parent_id=0。若传 max_level，会按层级裁剪。",
            "items": {
              "$ref": "#/components/schemas/MenuItem"
            }
          },
          "assigned_menu_ids": {
            "type": "array",
            "nullable": true,
            "description": "角色已分配菜单 ID 集合。当前后端在无数据时可能返回 null。",
            "items": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "example": [
              13,
              14
            ]
          },
          "direct_api_ids": {
            "type": "array",
            "nullable": true,
            "description": "角色直绑 API ID 集合。仅表示 role_apis 关系，不含菜单链路 API。当前后端在无数据时可能返回 null。",
            "items": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "example": [
              99
            ]
          },
          "assigned_api_ids": {
            "type": "array",
            "nullable": true,
            "description": "角色最终生效 API ID 集合，为菜单链路 API 与角色直绑 API 的并集。当前后端在无数据时可能返回 null。",
            "items": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "example": [
              10,
              11,
              99
            ]
          },
          "capability_groups": {
            "type": "array",
            "nullable": true,
            "description": "可配置 capability 分组列表。通常用于前端右侧 capability 勾选区域。",
            "items": {
              "$ref": "#/components/schemas/CapabilityGroupItem"
            }
          },
          "assigned_capability_codes": {
            "type": "array",
            "nullable": true,
            "description": "角色已分配 capability code 集合。当前后端在无数据时可能返回 null。",
            "items": {
              "type": "string"
            },
            "example": [
              "org.member.assign_role",
              "org.member.invite"
            ]
          }
        }
      },
      "MenuItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "菜单 ID",
            "example": 14
          },
          "parent_id": {
            "type": "integer",
            "format": "int64",
            "description": "父菜单 ID；0 表示顶级菜单",
            "example": 13
          },
          "name": {
            "type": "string",
            "description": "菜单名称",
            "example": "角色管理"
          },
          "code": {
            "type": "string",
            "description": "菜单权限标识 / 菜单编码",
            "example": "permission:role"
          },
          "type": {
            "type": "integer",
            "description": "菜单类型：1=目录，2=菜单，3=按钮",
            "enum": [
              1,
              2,
              3
            ],
            "example": 2
          },
          "icon": {
            "type": "string",
            "description": "菜单图标",
            "example": ""
          },
          "route_name": {
            "type": "string",
            "description": "前端路由名称",
            "example": "RoleManage"
          },
          "route_path": {
            "type": "string",
            "description": "前端路由路径",
            "example": "/console/permission/role"
          },
          "route_param": {
            "type": "string",
            "description": "路由参数串",
            "example": ""
          },
          "component_path": {
            "type": "string",
            "description": "前端组件路径",
            "example": "views/permission/role/index.vue"
          },
          "status": {
            "type": "integer",
            "description": "菜单状态：1=显示，0=隐藏",
            "enum": [
              0,
              1
            ],
            "example": 1
          },
          "sort": {
            "type": "integer",
            "description": "排序值，越小越靠前",
            "example": 1
          },
          "desc": {
            "type": "string",
            "description": "菜单描述",
            "example": "角色权限配置页"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间",
            "example": "2026-03-01T10:00:00+08:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间",
            "example": "2026-03-01T10:00:00+08:00"
          },
          "children": {
            "type": "array",
            "description": "子菜单列表。达到 max_level 上限或没有子节点时，后端可能直接省略该字段。",
            "items": {
              "$ref": "#/components/schemas/MenuItem"
            }
          },
          "apis": {
            "type": "array",
            "description": "菜单绑定的 API 列表，仅表示 menu_apis 关系。",
            "items": {
              "$ref": "#/components/schemas/APIItemSimple"
            }
          }
        }
      },
      "APIItemSimple": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "API ID",
            "example": 11
          },
          "path": {
            "type": "string",
            "description": "API 路由模板路径",
            "example": "/system/role/assign_permission"
          },
          "method": {
            "type": "string",
            "description": "HTTP 方法",
            "example": "POST"
          }
        }
      },
      "CapabilityGroupItem": {
        "type": "object",
        "properties": {
          "group_code": {
            "type": "string",
            "description": "能力分组编码",
            "example": "org_member_management"
          },
          "group_name": {
            "type": "string",
            "description": "能力分组名称",
            "example": "成员管理"
          },
          "capabilities": {
            "type": "array",
            "description": "分组下 capability 列表",
            "items": {
              "$ref": "#/components/schemas/CapabilityItem"
            }
          }
        }
      },
      "CapabilityItem": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "capability 唯一编码",
            "example": "org.member.assign_role"
          },
          "name": {
            "type": "string",
            "description": "capability 名称",
            "example": "分配成员角色"
          },
          "desc": {
            "type": "string",
            "description": "capability 描述",
            "example": "允许调整组织成员在本组织下的角色"
          },
          "status": {
            "type": "integer",
            "description": "状态：1=启用，0=禁用",
            "enum": [
              0,
              1
            ],
            "example": 1
          }
        }
      },
      "AuthResponseData": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "前端展示消息",
            "example": "Invalid access token"
          },
          "reload": {
            "type": "boolean",
            "description": "是否建议前端重置登录态 / 触发刷新流程",
            "example": true
          }
        }
      },
      "LegacyTokenErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "data",
          "error"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "旧版响应壳中的错误码",
            "example": 11003
          },
          "data": {
            "$ref": "#/components/schemas/AuthResponseData"
          },
          "error": {
            "type": "string",
            "description": "错误描述",
            "example": "Invalid access token"
          }
        }
      },
      "LegacyErrorEnvelope": {
        "type": "object",
        "required": [
          "code",
          "error"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "旧版响应壳中的错误码",
            "example": 11006
          },
          "data": {
            "nullable": true,
            "description": "旧版响应壳中的 data，权限中间件下常见为 {} 或错误对象序列化结果",
            "example": {}
          },
          "error": {
            "type": "string",
            "description": "错误描述",
            "example": "用户无权限访问API"
          }
        }
      }
    }
  }
}
